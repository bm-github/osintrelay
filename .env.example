# --- ChatOps (Telegram, Discord, or both) ---
# Set one or both.  The bot daemon auto-detects which to start.
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_HEALTH_CHECK_CHAT_ID="your_chat_id_here" # Optional: sends periodic online status
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_HEALTH_CHECK_CHANNEL_ID="your_channel_id_here" # Optional: sends a notification when bot comes online

# --- Watcher defaults (optional) ---
# How often the watcher wakes up to poll for new posts.
OSINT_WATCH_INTERVAL_SECONDS="300"
# Fetch limit per polling cycle per monitored target.
OSINT_WATCH_FETCH_LIMIT="20"
# Max number of newly-seen posts to include in each triage evaluation.
OSINT_WATCH_TRIAGE_POST_LIMIT="8"

# --- LLM (required) ---
LLM_API_KEY="your_llm_api_key"
LLM_API_BASE_URL="https://api.example.com/v1"
ANALYSIS_MODEL="your_text_analysis_model_name"
IMAGE_ANALYSIS_MODEL="your_vision_model_name"

# --- Platforms (configure as needed) ---
TWITTER_BEARER_TOKEN="your_twitter_bearer_token"
REDDIT_CLIENT_ID="your_reddit_client_id"
REDDIT_CLIENT_SECRET="your_reddit_client_secret"
REDDIT_USER_AGENT="YourApp/1.0 by YourUsername"
BLUESKY_IDENTIFIER="your-handle.bsky.social"
BLUESKY_APP_SECRET="your_bluesky_app_secret"
GITHUB_TOKEN="your_github_token"

# Mastodon instance(s)
MASTODON_INSTANCE_1_URL="https://mastodon.social"
MASTODON_INSTANCE_1_TOKEN="your_access_token"
MASTODON_INSTANCE_1_DEFAULT="true"

# Note on Discord:
# - For native Discord bot: set DISCORD_BOT_TOKEN above.
# - For webhook-only alerts (from Telegram): use /monitor_discord with a webhook URL.
#   No DISCORD_BOT_TOKEN needed for webhook mode.

