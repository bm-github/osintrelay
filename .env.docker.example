# Docker Environment Configuration Example
# Copy this to .env and fill in your actual values

# LLM Configuration (Required)
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE_URL=https://api.openai.com/v1
IMAGE_ANALYSIS_MODEL=gpt-4o-mini
ANALYSIS_MODEL=gpt-4o-mini
TRIAGE_MODEL=gpt-4o-mini

# Platform Credentials
# Twitter/X
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Reddit
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=osint-relay/1.0

# Bluesky
BLUESKY_IDENTIFIER=your_bluesky_identifier
BLUESKY_PASSWORD=your_bluesky_app_password

# Mastodon (Optional - for multiple instances, use comma-separated values)
MASTODON_ACCESS_TOKENS=instance1:token1,instance2:token2

# Discord Bot (for bot service)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id

# Telegram Bot (for bot service)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Health Check Channels (Optional - for startup notifications)
TELEGRAM_HEALTH_CHECK_CHAT_ID=
DISCORD_HEALTH_CHECK_CHANNEL_ID=

# Docker-specific Configuration
# Watcher Configuration
OSINT_WATCH_INTERVAL_SECONDS=300
OSINT_WATCH_FETCH_LIMIT=20
OSINT_WATCH_TRIAGE_POST_LIMIT=8

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Security Settings
# Set to true to allow downloading media from arbitrary external domains
# WARNING: This may expose your system to security risks
UNSAFE_ALLOW_EXTERNAL_MEDIA=false
